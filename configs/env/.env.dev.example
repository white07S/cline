# Copy to .env.dev and fill in. NEVER commit .env.dev.
# Loaded by docker compose and pydantic-settings.

# ── App ──────────────────────────────────────────────────────────
APP_ENV=dev
# CONFIG_DIR — leave unset for local dev (settings.py auto-derives from this file's location).
# Docker compose sets it to /app/configs.
# CONFIG_DIR=
LOG_LEVEL=DEBUG

# ── Postgres ─────────────────────────────────────────────────────
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
DATABASE_URL=postgresql+asyncpg://app:app@postgres:5432/app
# Sync DSN used by Alembic.
DATABASE_URL_SYNC=postgresql+psycopg://app:app@postgres:5432/app

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Qdrant ───────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ── MinIO / S3 ───────────────────────────────────────────────────
# MinIO is the object store in every environment. The S3_* vars MUST match
# MINIO_ROOT_USER / MINIO_ROOT_PASSWORD — the app talks to the bundled minio
# service via the docker-compose network. Rotate these for any non-local use.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1

# ── Dagster ──────────────────────────────────────────────────────
# DAGSTER_HOME holds the instance config + local compute logs. Mounted as a
# named volume in compose so it survives restarts.
DAGSTER_HOME=/app/dagster_home
# Dagster's run/event/schedule storage uses a separate Postgres database
# (created by configs/infra/postgres/init/01-create-dagster-db.sh).
DAGSTER_POSTGRES_DB=dagster
# POSTGRES_HOST is used by dagster.yaml to construct its DSN. Inside the
# docker-compose network the postgres service is reachable as `postgres`.
POSTGRES_HOST=postgres

# ── OpenAI ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# If using Azure OpenAI:
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=

# ── Azure AD (MSAL) ──────────────────────────────────────────────
# Server validates tokens with these (decision deferred — set when ready).
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_API_AUDIENCE=

# ── Sentry ───────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=dev
SENTRY_TRACES_SAMPLE_RATE=1.0

# ── OTEL ─────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=api
