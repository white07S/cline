# Copy to .env.prod and fill in. NEVER commit .env.prod.
# These values land in production — treat as sensitive.

# ── App ──────────────────────────────────────────────────────────
APP_ENV=prod
# CONFIG_DIR is set to /app/configs by docker-compose.prod.yml.
LOG_LEVEL=INFO

# ── Postgres ─────────────────────────────────────────────────────
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DB
DATABASE_URL_SYNC=postgresql+psycopg://USER:PASSWORD@HOST:5432/DB

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://HOST:6379

# ── Qdrant ───────────────────────────────────────────────────────
QDRANT_URL=https://qdrant.internal:6333
QDRANT_API_KEY=

# ── MinIO / S3 ───────────────────────────────────────────────────
# Object storage is MinIO in both dev and prod. The S3_* vars below MUST
# match the MinIO root credentials — app code talks to the bundled minio
# service via the docker-compose network. ROTATE these before deploying.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1

# ── Dagster ──────────────────────────────────────────────────────
DAGSTER_HOME=/app/dagster_home
DAGSTER_POSTGRES_DB=dagster
POSTGRES_HOST=postgres

# ── OpenAI ───────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Azure AD (MSAL) ──────────────────────────────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_API_AUDIENCE=

# ── Sentry ───────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=prod
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── OTEL ─────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=api

# ── Grafana admin (used by docker-compose.prod.yml) ──────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=
