# Copy to .env.prod and fill in. NEVER commit .env.prod.
# These values land in production — treat as sensitive.

# ── App ──────────────────────────────────────────────────────────
APP_ENV=prod
# CONFIG_DIR is set to /app/configs by docker-compose.prod.yml.
LOG_LEVEL=INFO

# ── Postgres ─────────────────────────────────────────────────────
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DB
DATABASE_URL_SYNC=postgresql+psycopg://USER:PASSWORD@HOST:5432/DB

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://HOST:6379

# ── Qdrant ───────────────────────────────────────────────────────
QDRANT_URL=https://qdrant.internal:6333
QDRANT_API_KEY=

# ── OpenAI ───────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Azure AD (MSAL) ──────────────────────────────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_API_AUDIENCE=

# ── Sentry ───────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=prod
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── OTEL ─────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=api

# ── Grafana admin (used by docker-compose.prod.yml) ──────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=
