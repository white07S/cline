    "lint": "biome check . && eslint .",
    "format": "biome format --write .",
    "generate-routes": "node scripts/generate-routes.mjs",
    "typecheck": "node scripts/generate-routes.mjs && tsc --noEmit",
    "e2e": "playwright test"
  },
  "dependencies": {
