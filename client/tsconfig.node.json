{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "strict": true,
    // Composite projects must emit. Send the .d.ts/.tsbuildinfo to a cache
    // directory (gitignored) instead of leaving them next to source — Vite
    // does its own bundling, so tsc -b is purely a type-check pass here.
    "outDir": ".ts-build"
  },
  // vitest.config.ts and playwright.config.ts are intentionally excluded:
  // their own embedded copies of vite/types collide with the top-level vite,
  // and they're loaded directly by their tools at runtime — they don't need
  // to be part of the typed program.
  "include": ["vite.config.ts"]
}
